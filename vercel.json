{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/uploads/(.*)",
            "dest": "/public/uploads/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/chat(\\.html)?$",
            "dest": "/public/chat.html"
        },
        {
            "src": "/dashboard(\\.html)?$",
            "dest": "/public/dashboard.html"
        },
        {
            "src": "/home(\\.html)?$",
            "dest": "/public/home.html"
        },
        {
            "src": "/about(\\.html)?$",
            "dest": "/public/about.html"
        },
        {
            "src": "/(.*\\.(html|css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot))",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.js"
        }
    ]
}